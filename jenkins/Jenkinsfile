pipeline {
    agent any

    environment {
        IMAGE = "devsecops-app"
        TAG = "${BUILD_NUMBER}"
    }

    stages {

        stage('Build') {
            steps {
                sh '''
                    docker build -t $IMAGE:$TAG -t $IMAGE:latest -f docker/Dockerfile .
                '''
            }
        }

        stage('SonarQube') {
            steps {
                withSonarQubeEnv('sonar') {
                    sh '/opt/sonar-scanner/bin/sonar-scanner -Dproject.settings=sonar/sonar-project.properties'
                }
            }
        }

        stage('Trivy - Scan Report') {
            steps {
                sh '''
                    export TRIVY_CACHE_DIR=/tmp/trivy-cache-$BUILD_ID

                    trivy image \
                        --format table \
                        -o trivy-report.txt \
                        $IMAGE:$TAG
                '''
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                    echo "Stopping container if exists..."
                    docker stop devsecops-app || true

                    echo "Removing container if exists..."
                    docker rm -f devsecops-app || true

                    echo "Starting new container..."
                    docker run -d \
                        --name devsecops-app \
                        -p 5000:5000 \
                        $IMAGE:$TAG
                '''
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'trivy-report.txt', allowEmptyArchive: true
        }
    }
}