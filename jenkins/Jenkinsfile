def sendSlack(msg) {
    sh """
        curl -X POST -H 'Content-type: application/json' \
        --data '{"text": "${msg}"}' \
        $SLACK_WEBHOOK
    """
}

pipeline {
    agent any

    options {
        disableConcurrentBuilds()
        timestamps()
    }

    environment {
        IMAGE = "devsecops-app"
        TAG = "${BUILD_NUMBER}-${GIT_COMMIT}"
        TRIVY_CACHE_DIR = "/tmp/trivy-cache-${BUILD_ID}"
        SLACK_WEBHOOK = credentials('slack-webhook')
    }

    stages {

        stage('Build') {
            steps {
                sh 'docker build -t $IMAGE:$TAG -f docker/Dockerfile .'
            }
        }

        stage('Tests + Coverage') {
            steps {
                sh '''
                    set -e

                    python3 -m venv venv
                    . venv/bin/activate

                    python -m pip install --upgrade pip
                    python -m pip install -r app/requirements.txt

                    export PYTHONPATH=.
                    python -m pytest --cov=app --cov-report=xml:coverage.xml
                '''
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonar') {
                    sh '''
                        /opt/sonar-scanner/bin/sonar-scanner \
                        -Dproject.settings=sonar/sonar-project.properties
                    '''
                }
            }
        }

        stage('Quality Gate (Non Blocking)') {
            steps {
                script {
                    try {
                        timeout(time: 10, unit: 'SECONDS') {
                            def qg = waitForQualityGate abortPipeline: false
                            echo "Quality Gate status: ${qg.status}"

                            if (qg.status != 'OK') {
                                sendSlack("""
⚠️ *SONAR ALERT*
Projeto: ${env.JOB_NAME}
Status: ${qg.status}
🔗 ${env.BUILD_URL}
""")
                            }
                        }
                    } catch (err) {
                        echo "Sonar ainda processando"
                    }
                }
            }
        }

        stage('Security Scan (Trivy)') {
            steps {
                sh '''
                    mkdir -p $TRIVY_CACHE_DIR

                    trivy image \
                        --cache-dir $TRIVY_CACHE_DIR \
                        --severity CRITICAL,HIGH \
                        --format table \
                        -o trivy-report.txt \
                        $IMAGE:$TAG || true
                '''
            }
            post {
                always {
                    script {
                        sendSlack("🔐 Trivy scan finalizado para ${env.JOB_NAME} #${env.BUILD_NUMBER}")
                    }
                }
            }
        }

        stage('Deploy Staging') {
            when {
                anyOf {
                    branch 'develop'
                    expression { return env.BRANCH_NAME?.startsWith("feature/") }
                }
            }
            steps {
                sh '''
                    docker stop devsecops-staging || true
                    docker rm -f devsecops-staging || true

                    docker run -d \
                        --name devsecops-staging \
                        -p 5001:5000 \
                        $IMAGE:$TAG
                '''
            }
            post {
                success {
                    script {
                        sendSlack("🚀 Deploy STAGING realizado com sucesso")
                    }
                }
            }
        }

        stage('Approval for Production') {
            when {
                branch 'main'
            }
            steps {
                input message: "Approve deployment to PRODUCTION?"
            }
        }

        stage('Deploy Production') {
            when {
                branch 'main'
            }
            steps {
                sh '''
                    set -e

                    PREVIOUS=$(docker images --format "{{.Repository}}:{{.Tag}}" \
                        | grep devsecops-app \
                        | grep -v "$TAG" \
                        | head -n 1 || true)

                    docker stop devsecops-app || true
                    docker rm -f devsecops-app || true

                    docker run -d \
                        --name devsecops-app \
                        -p 5000:5000 \
                        $IMAGE:$TAG

                    sleep 8

                    if ! curl -f http://localhost:5000/; then
                        echo "ROLLBACK..."

                        docker stop devsecops-app || true
                        docker rm -f devsecops-app || true

                        if [ ! -z "$PREVIOUS" ]; then
                            docker run -d \
                                --name devsecops-app \
                                -p 5000:5000 \
                                $PREVIOUS
                        fi

                        exit 1
                    fi
                '''
            }
            post {
                success {
                    script {
                        sendSlack("🚀 *PRODUÇÃO ATUALIZADA* com sucesso")
                    }
                }
                failure {
                    script {
                        sendSlack("❌ Falha no deploy em produção (rollback executado)")
                    }
                }
            }
        }
    }

    post {
        success {
            script {
                sendSlack("""
✅ *PIPELINE SUCESSO*
Projeto: ${env.JOB_NAME}
Build: #${env.BUILD_NUMBER}
🌿 Branch: ${env.BRANCH_NAME}
🔗 ${env.BUILD_URL}
""")
            }
        }

        failure {
            script {
                sendSlack("""
❌ *PIPELINE FALHOU*
Projeto: ${env.JOB_NAME}
Build: #${env.BUILD_NUMBER}
🌿 Branch: ${env.BRANCH_NAME}
🔗 ${env.BUILD_URL}
""")
            }
        }

        always {
            sh '''
                docker system prune -f || true
                rm -rf /tmp/trivy-cache || true
            '''

            archiveArtifacts artifacts: 'trivy-report.txt', allowEmptyArchive: true
        }
    }
}