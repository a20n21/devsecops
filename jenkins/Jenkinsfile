pipeline {
    agent any

    environment {
        IMAGE = "devsecops-app"
    }

    tools {
        sonarQubeScanner 'sonar-scanner'
    }

    stages {

        stage('Build') {
            steps {
                sh 'docker build -t $IMAGE -f docker/Dockerfile .'
            }
        }

        stage('SonarQube') {
            steps {
                withSonarQubeEnv('sonar') {
                    sh '''
                    sonar-scanner \
                      -Dproject.settings=sonar/sonar-project.properties
                    '''
                }
            }
        }

        stage('Trivy') {
            steps {
                sh 'trivy image $IMAGE'
            }
        }
    }
}