pipeline {
    agent any

    environment {
        IMAGE = "devsecops-app"
    }

    stages {

        stage('Build') {
            steps {
                sh 'docker build -t $IMAGE -f docker/Dockerfile .'
            }
        }

        stage('SonarQube') {
            steps {
                withSonarQubeEnv('sonar') {
                    sh '/opt/sonar-scanner/bin/sonar-scanner -Dproject.settings=sonar/sonar-project.properties'
                }
            }
        }

        stage('Trivy - Scan Report') {
            steps {
                sh '''
                    trivy image --format table -o trivy-report.txt $IMAGE
                '''
            }
        }

    }

    post {
        always {
            archiveArtifacts artifacts: 'trivy-report.txt', onlyIfSuccessful: false
        }
    }
}